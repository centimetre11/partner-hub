DATABASE_URL="file:./dev.db"
SESSION_SECRET="change-me-to-a-long-random-string-in-production"

# OpenAI 兼容接口兜底配置（可选；推荐在「团队设置 → 大模型管理中心」添加 API，Web 助手 / 企微机器人 / Agent 共用）
AI_BASE_URL="https://api.moonshot.cn/v1"
AI_API_KEY=""
AI_MODEL="kimi-k2-0711-preview"
# 轻量 AI 录入（商务记录/待办/企微 Propose 等 fast 路径）单次最大输出 token，默认 800
# FAST_INTAKE_MAX_TOKENS="800"

# 联网搜索：由大模型内置能力提供（Kimi $web_search 或火山引擎 web_search），无需单独搜索 API Key
# 也兼容旧变量名 PROXYCURL_API_KEY。Key 在 https://nubela.co/dashboard 获取。
NINJAPEARL_API_KEY=""

# 本地上传目录（Docker 建议 /data/uploads）
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB="500"

# 过伙伴会议录音转写（科大讯飞实时语音转写大模型，WebSocket）
# 在讯飞开放平台开通「实时语音转写大模型」，控制台获取 AppID / APIKey / APISecret
# XFYUN_APP_ID=""
# XFYUN_API_KEY=""
# XFYUN_API_SECRET=""
# XFYUN_LANG="autodialect"
# 领域优化：com=企业/ecom=电商/med=医疗 等，见讯飞文档 pd 参数
# XFYUN_PD="com"
# 1=远场 2=近场（笔记本麦克风建议 2）
# XFYUN_VAD_MDN="2"
# XFYUN_RTASR_WS_HOST="wss://office-api-ast-dx.iflyaisol.com/ast/communicate/v1"

# 旧版自托管 Whisper（已下架，勿再配置 ASR_BASE_URL）
# ASR_BASE_URL="http://127.0.0.1:9000"

# Google 云盘弹药库（也可在团队设置 → 弹药库配置）
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# GDRIVE_FOLDER_URL="https://drive.google.com/drive/folders/..."

# Google Drive 文件上传（OAuth 真人账号；服务账号无法往个人云盘上传）
# 在 Google Cloud 建 OAuth 客户端（Web 应用），发布到 production（避免 refresh token 7 天过期），
# 授权回调填 ${APP_BASE_URL}/api/google/oauth/callback。也可在团队设置 → 弹药库配置 中填写并连接账号。
# 会议 Meet 链接（每人授权自己的 Gmail）：同一 OAuth 客户端，另需在 GCP 启用 Calendar API，
# 同意屏增加 calendar.events scope，回调增加 ${APP_BASE_URL}/api/google/meet/oauth/callback
# APP_BASE_URL="http://localhost:3000"
# GOOGLE_OAUTH_CLIENT_ID="xxxxxx.apps.googleusercontent.com"
# GOOGLE_OAUTH_CLIENT_SECRET=""
# 客户/伙伴材料归档父目录（07_Client Information，可选覆盖）
# GDRIVE_CLIENT_MATERIALS_FOLDER_URL="https://drive.google.com/drive/folders/1xVS1M2Qpa0ql-9VATWiUfepU9BTcfy-L"

# 团队级 KMS 回退令牌（用户未在个人中心配置时使用；也可在团队设置中配置）
# KMS_SYSTEM_TOKEN=""
# KMS_SYSTEM_BASE_URL="https://kms.fineres.com"

# 团队级 Know-how 知识库检索 API 令牌（也可在团队设置中配置）
# KNOWHOW_API_KEY=""
# KNOWHOW_BASE_URL="https://digitchat.fanruan.com/dataset"
# KH 平台搜索入口根地址（无元数据链接时，按文档标题拼接 /search?query=）
# KNOWHOW_SEARCH_ENTRY_BASE_URL="https://knowhow.fanruan.com"
# KNOWHOW_WEB_BASE_URL="https://digitchat.fanruan.com"

# 企业微信智能机器人（长连接模式，无需公网回调地址）
# 在企微后台：工作台 → 智能机器人 → 创建 → API 模式 → 使用长连接 → 获取 Bot ID 和 Secret
WECOM_BOT_ID=""
WECOM_BOT_SECRET=""
# 应用消息里展示的机器人名称（引导用户搜索私聊），例如 MENA Beard Gang
# WECOM_BOT_DISPLAY_NAME="MEA 伙伴助手"
# 可选：私有化部署的 WebSocket 地址，默认 wss://openws.work.weixin.qq.com
# WECOM_BOT_WS_URL=""
# 可选：机器人以哪个系统用户身份调用 AI 工具（默认第一个 ADMIN）
# WECOM_BOT_USER_ID=""
# 设为 1 时随 next dev/start 自动启动机器人；开发时也可单独运行 npm run wecom-bot
WECOM_BOT_AUTOSTART="0"

# 企业微信自建应用网页授权登录
# 自建应用详情中复制 CorpID（企业 ID）和 Secret（应用密钥）；后台需把后端服务器外网出口 IP 加入白名单
# APP_BASE_URL 必须是企微可访问的 HTTPS 域名，例如 https://partner.example.com
# WECOM_AGENT_ID 可选；网页授权或 send_wecom_app 应用消息推送时需填写应用 AgentId
# 工作台「创建会议」还需在企微管理后台为自建应用开启「日程」API（oa/schedule/add）
# 企微工作台「应用主页」建议:
#   手机端: ${APP_BASE_URL}/api/wecom/oauth/start?redirect=%2Fmobile
#   PC 端:  ${APP_BASE_URL}/api/wecom/oauth/start?redirect=%2F
# 若手机/PC 共用同一主页，可只填 ${APP_BASE_URL}/api/wecom/oauth/start（按 UA 自动跳转 mobile 或桌面首页）
# APP_BASE_URL="https://partner.example.com"
# WECOM_CORP_ID="wwxxxxxxxxxxxxxxxx"
# WECOM_APP_SECRET=""
# WECOM_AGENT_ID=""
# 可选：仅本地测试/私有代理时覆盖企微 API 域名，默认 https://qyapi.weixin.qq.com
# WECOM_API_BASE_URL="https://qyapi.weixin.qq.com"

# 钉钉开放平台（开会过伙伴 / A1 录音转写；也可在团队设置 → 外部集成配置）
# 回调地址: ${APP_BASE_URL}/api/dingtalk/callback
# DINGTALK_CORP_ID=""
# DINGTALK_APP_KEY=""
# DINGTALK_APP_SECRET=""
# DINGTALK_TOKEN=""
# DINGTALK_AES_KEY=""
# DINGTALK_AGENT_ID=""
# DINGTALK_ENABLED="true"

# 帆软 CRM 数据同步（客户/联系人每日拉取）
# CRM_DATA_URL="https://crm.finereporthelp.com/WebReport/decision/url/pub/crm/data?id=fa8f9bcb42b247a7880688336242e40d&secret=zd123456"
# CRM_SYNC_INTERVAL_HOURS="24"
# CRM_SYNC_FAIL_BACKOFF_MINUTES="60"
# CRM_SYNC_ENABLED="1"
# CRM_TRACE_SUBMIT_URL="https://crm.finereporthelp.com/WebReport/decision/url/datainputcrm/submit?id=zd_trce_in&secret=zd12345"
# CRM_TRACE_ENABLED="1"
# 身份绑定下拉补录：售前/项目等（每行或逗号分隔），与团队设置「补录 CRM 录入人」二选一
# CRM_EXTRA_RECORDERS="Zayne.Zhao\nXuShengkai"

# 帆软 CRM 线索同步（每天利雅得 05:00 全量拉取 2026 年线索；接口需 IP 加白名单）
# LEADS_DATA_URL="https://crm.fineres.com/crm/api/pub/data?id=79a8c7c489314494ba78eed58d269c8a&secret=crm123"
# LEADS_SYNC_CRON="0 5 * * *"
# LEADS_SYNC_TIMEZONE="Asia/Riyadh"
# LEADS_SYNC_ENABLED="1"

# CRM 填报成功回调 Partner Hub（与 crm-integration 文档配套）
# 所有 action 共用一个密钥，不是每个接口一把
# CRM_CALLBACK_SECRET="请生成随机密钥，CRM Java/JS 回调 Header 使用同一值"
# CRM_CALLBACK_TEST_CLUE_ID="7120c4b1-83f1-4acd-9f21-d661e316f5e9"  # 可选，测试页 sampleClueId

# QQ 邮箱 SMTP（也可在团队设置 → 邮件服务 中配置）
# SMTP_HOST="smtp.qq.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="yourname@qq.com"
# SMTP_PASS="your-qq-smtp-auth-code"
# SMTP_FROM_NAME="Partner Hub"
