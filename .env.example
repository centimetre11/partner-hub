DATABASE_URL="file:./dev.db"
SESSION_SECRET="change-me-to-a-long-random-string-in-production"

# OpenAI 兼容接口兜底配置（可选；推荐在「团队设置 → 大模型管理中心」添加 API，Web 助手 / 企微机器人 / Agent 共用）
AI_BASE_URL="https://api.moonshot.cn/v1"
AI_API_KEY=""
AI_MODEL="kimi-k2-0711-preview"
# 轻量 AI 录入（商务记录/待办/企微 Propose 等 fast 路径）单次最大输出 token，默认 800
# FAST_INTAKE_MAX_TOKENS="800"

# 联网搜索：由大模型内置能力提供（Kimi $web_search 或火山引擎 web_search），无需单独搜索 API Key
# 也兼容旧变量名 PROXYCURL_API_KEY。Key 在 https://nubela.co/dashboard 获取。
NINJAPEARL_API_KEY=""

# 本地上传目录（Docker 建议 /data/uploads）
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB="20"

# Google 云盘弹药库（也可在团队设置 → 弹药库配置）
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# GDRIVE_FOLDER_URL="https://drive.google.com/drive/folders/..."

# 团队级 KMS 回退令牌（用户未在个人中心配置时使用；也可在团队设置中配置）
# KMS_SYSTEM_TOKEN=""
# KMS_SYSTEM_BASE_URL="https://kms.fineres.com"

# 团队级 Know-how 知识库检索 API 令牌（也可在团队设置中配置）
# KNOWHOW_API_KEY=""
# KNOWHOW_BASE_URL="https://digitchat.fanruan.com/dataset"
# KNOWHOW_WEB_BASE_URL="https://digitchat.fanruan.com"

# 企业微信智能机器人（长连接模式，无需公网回调地址）
# 在企微后台：工作台 → 智能机器人 → 创建 → API 模式 → 使用长连接 → 获取 Bot ID 和 Secret
WECOM_BOT_ID=""
WECOM_BOT_SECRET=""
# 可选：私有化部署的 WebSocket 地址，默认 wss://openws.work.weixin.qq.com
# WECOM_BOT_WS_URL=""
# 可选：机器人以哪个系统用户身份调用 AI 工具（默认第一个 ADMIN）
# WECOM_BOT_USER_ID=""
# 设为 1 时随 next dev/start 自动启动机器人；开发时也可单独运行 npm run wecom-bot
WECOM_BOT_AUTOSTART="0"

# 帆软 CRM 数据同步（客户/联系人每日拉取）
# CRM_DATA_URL="https://crm.finereporthelp.com/WebReport/decision/url/pub/crm/data?id=fa8f9bcb42b247a7880688336242e40d&secret=zd123456"
# CRM_SYNC_INTERVAL_HOURS="24"
# CRM_SYNC_ENABLED="1"
# CRM_TRACE_SUBMIT_URL="https://crm.finereporthelp.com/WebReport/decision/url/datainputcrm/submit?id=zd_trce_in&secret=zd12345"
# CRM_TRACE_ENABLED="1"
# 身份绑定下拉补录：售前/项目等（每行或逗号分隔），与团队设置「补录 CRM 录入人」二选一
# CRM_EXTRA_RECORDERS="Zayne.Zhao\nXuShengkai"
