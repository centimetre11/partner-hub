DATABASE_URL="file:./dev.db"
SESSION_SECRET="change-me-to-a-long-random-string-in-production"

# OpenAI 兼容接口兜底配置（推荐登录后在「团队设置 → 大模型管理中心」添加多个 API）
AI_BASE_URL="https://api.moonshot.cn/v1"
AI_API_KEY=""
AI_MODEL="kimi-k2-0711-preview"

# 联网搜索（Agent 的 web_search 技能）：
# 配置 Tavily Key 优先用 Tavily（https://tavily.com 免费额度）；
# 不配且 AI_BASE_URL 是 moonshot（Kimi）时自动改用 Kimi 内置 $web_search。
TAVILY_API_KEY=""

# 本地上传目录（Docker 建议 /data/uploads）
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB="20"
