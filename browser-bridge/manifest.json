{
  "manifest_version": 3,
  "name": "Partner Hub 浏览器助手",
  "version": "1.1.10",
  "description": "Partner Hub 的浏览器操作桥：企业邮写信自动填充；CRM 海外激活填报表自动预填。",
  "key": "",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Partner Hub 浏览器助手"
  },
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "https://exmail.qq.com/*",
    "https://*.exmail.qq.com/*",
    "https://mail.qq.com/*",
    "https://*.mail.qq.com/*",
    "https://work.weixin.qq.com/*",
    "https://crm.finereporthelp.com/*",
    "https://*.finereporthelp.com/*",
    "https://camelusai.com/*",
    "http://localhost:3000/*"
  ],
  "externally_connectable": {
    "matches": ["https://camelusai.com/*", "http://localhost:3000/*"]
  }
}
