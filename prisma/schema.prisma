generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  name         String
  passwordHash String
  // SALES 销售 / PRESALES 售前 / ADMIN 管理员 / OTHER 其他
  role         String          @default("OTHER")
  createdAt    DateTime        @default(now())
  partners     Partner[]
  salesPartners    Partner[] @relation("PartnerSalesUser")
  presalesPartners Partner[] @relation("PartnerPresalesUser")
  todos        TodoItem[]
  events       TimelineEvent[]
  agents       Agent[]
  assets       Asset[]
  documents    Document[]
  materials    Material[]
  knowledgeArticles KnowledgeArticle[]
  gtmLibraryItems   GtmLibrary[]
  taxonomyOptions   TaxonomyOption[]
  skills       Skill[]
  aiTokenUsages AiTokenUsage[]
  kmsCredential UserKmsCredential?
  businessRecords BusinessRecord[]
  crmSalesmanName String? // 帆软 CRM 销售英文名，对应 com_salesman（如 Fay.Wen）
}

model Partner {
  id               String   @id @default(cuid())
  name             String   @unique
  // PROSPECT 候选 / ACTIVE 正式 / ARCHIVED 归档
  status           String   @default("PROSPECT")
  // 归档前的状态，用于恢复时原样还原
  prevStatus       String?
  // NEW 新候选 / ADVANCING 推进中 / WATCHING 观察 / DROPPED 放弃
  poolFlag         String   @default("NEW")
  // PURE_DATA / POWER_BI / TABLEAU / QLIK / IT_INTEGRATOR / OTHER
  category         String   @default("OTHER")
  // BANKING / … / OTHER（兼容旧数据；新数据用 industries）
  industry         String?
  industries       String?  // JSON 数组，主攻行业多选
  // DATA_NATIVE / BI_MIGRATOR / IT_INTEGRATOR / IOT_INTEGRATOR / SALES_AGENT / SHELL_DATA / OTHER
  partnerArchetype String?
  // IOT_DASH / APP_REPORT / CLOUD_APP / DATA_BI / BI_COMPLEMENT / OEM_EMBED / GOV_BID
  valuePattern     String?
  valuePartnerOffer String? // 伙伴提供什么
  valueFanruanOffer String? // 帆软提供什么
  valueCustomerOutcome String? // 客户得到什么
  dedicatedHeadcount String? // 专职做帆软/数据业务人数
  tier             String? // A / B / C
  city             String?
  country          String?
  headcount        String?
  website          String?
  companyType      String?
  coreBusiness     String?
  capability       String?
  knownClients     String?
  certLevel        String?
  currentTools     String?
  keyDifferentiator String?
  playbook         String?
  pitch            String?
  bestChannel      String?
  fitScore         Int?
  priority         String? // P0 / P1 / P2 / P3
  aiVerified       String? // VERIFIED / PARTIAL / UNKNOWN
  manualChecked    Boolean  @default(false)
  monitorDims      String? // JSON 数组：舆情监控勾选的维度
  kmsRootPath      String? // KMS 主目录，手动填写
  crmCustomerId    String? // 帆软 CRM 客户 ID
  pipelineStage    Int      @default(1) // 1-10 十阶段
  ownerId          String?
  owner            User?    @relation(fields: [ownerId], references: [id])
  salesUserId      String?
  salesUser        User?    @relation("PartnerSalesUser", fields: [salesUserId], references: [id])
  presalesUserId   String?
  presalesUser     User?    @relation("PartnerPresalesUser", fields: [presalesUserId], references: [id])
  promotedAt       DateTime?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  contacts      Contact[]
  contactLinks  ContactLink[]
  opportunities Opportunity[]
  todos         TodoItem[]
  events        TimelineEvent[]
  trainings     Training[]
  agents        Agent[]
  solutions     Solution[]
  documents     Document[]
  monitorSources MonitorSource[]
  monitorItems  MonitorItem[]
  wecomChat     WecomChat?
  businessRecords BusinessRecord[]
}

// 商务记录：伙伴关键进展（双写活动线 MILESTONE）
model BusinessRecord {
  id              String    @id @default(cuid())
  partnerId       String
  partner         Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  category        String    // VISIT / TRAINING / NEGOTIATION / DELIVERY / RELATIONSHIP / OTHER
  title           String
  content         String?
  occurredAt      DateTime  @default(now())
  contactId       String?
  contact         Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  timelineEventId String?   @unique
  sourceTodoId    String?
  source          String    @default("MANUAL") // MANUAL / TODO / RELATIONSHIP_TAB
  createdById     String?
  createdBy       User?     @relation(fields: [createdById], references: [id])
  crmTraceId      String?
  crmSyncedAt     DateTime?
  crmSyncError    String?
  createdAt       DateTime  @default(now())

  @@index([partnerId, occurredAt])
}

// 企业微信会话（群聊/单聊），可与伙伴绑定用于主动推送
model WecomChat {
  id         String   @id @default(cuid())
  chatId     String   @unique
  chatType   String   @default("group") // group | single
  label      String?
  partnerId  String?  @unique
  partner    Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 企微主动推送队列（由 wecom-bot 容器消费）
model WecomPushJob {
  id        String    @id @default(cuid())
  chatId    String
  content   String
  status    String    @default("PENDING") // PENDING | SENT | FAILED
  error     String?
  createdAt DateTime  @default(now())
  sentAt    DateTime?

  @@index([status, createdAt])
}

// 打法库：playbook + pitch 存档（支持同标题多版本）
model GtmLibrary {
  id               String   @id @default(cuid())
  title            String
  playbook         String?
  pitch            String?
  industry         String?
  industries       String?
  valuePattern     String?
  partnerArchetype String?
  category         String?
  notes            String?
  version          Int      @default(1)
  groupId          String   // 同一组 = 同一打法的不同版本
  sourcePartnerId  String?
  sourcePartnerName String?
  createdById      String?
  createdBy        User?    @relation(fields: [createdById], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([groupId])
  @@index([title])
}

// 维度库：伙伴类型 / 行业 / 价值模式 / 竞品基因 的可扩展选项
model TaxonomyOption {
  id          String   @id @default(cuid())
  dimension   String   // ARCHETYPE | INDUSTRY | VALUE_PATTERN | CATEGORY
  code        String
  label       String
  description String?
  sortOrder   Int      @default(0)
  isBuiltin   Boolean  @default(false)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dimension, code])
  @@index([dimension])
}

// 舆情监控：自定义监控链接源（领英/Facebook 主页、官网、新闻源等）
model MonitorSource {
  id           String   @id @default(cuid())
  partnerId    String
  partner      Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  label        String
  url          String
  // LINKEDIN / FACEBOOK / X / WEBSITE / NEWS / CUSTOM
  sourceType   String   @default("CUSTOM")
  domain       String? // 用于 site: 过滤
  title        String? // 链接预览标题
  thumbnailUrl String?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([partnerId])
}

// 舆情监控：扫描并经 AI 分类后的舆情条目
model MonitorItem {
  id          String    @id @default(cuid())
  partnerId   String
  partner     Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  // NEWS / PEOPLE / HIRING / DEALS / FUNDING / COMPETITOR / SOCIAL / REPUTATION / EVENTS / ALLIANCE / RISK
  dimension   String    @default("NEWS")
  // POSITIVE / NEUTRAL / NEGATIVE / RISK
  sentiment   String    @default("NEUTRAL")
  title       String
  summary     String?
  url         String?
  sourceName  String?
  sourceType  String    @default("web") // web / linkedin / custom
  publishedAt DateTime?
  dedupeKey   String
  status      String    @default("NEW") // NEW / ARCHIVED
  createdAt   DateTime  @default(now())

  @@unique([partnerId, dedupeKey])
  @@index([partnerId])
}

model Contact {
  id          String    @id @default(cuid())
  partnerId   String
  partner     Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name        String
  // APPROVER(A审批者) / DECISION_MAKER(D决策者) / SUPPORTER(S支持者) / EVALUATOR(E评估者) / INFLUENCER(I影响者)
  role        String    @default("INFLUENCER")
  title       String?
  department  String? // 部门
  attitude    Int       @default(0) // 3教练 / 2支持并排他 / 1支持不排他 / 0未接触或中立 / -1反对
  reportsToId String? // 汇报上级（主汇报实线）
  reportsTo   Contact?  @relation("ContactReports", fields: [reportsToId], references: [id], onDelete: SetNull)
  reports     Contact[] @relation("ContactReports")
  x           Float? // 权力地图手动摆放坐标（null = 自动布局）
  y           Float?
  linksAsSub  ContactLink[] @relation("LinkSub") // 作为下级的附加汇报线
  linksAsSup  ContactLink[] @relation("LinkSup") // 作为上级的附加汇报线
  contactInfo String?
  approach    String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  businessRecords BusinessRecord[]
}

// 附加汇报线（虚线/双线汇报）。主汇报实线仍走 Contact.reportsToId
model ContactLink {
  id            String   @id @default(cuid())
  partnerId     String
  partner       Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  subordinateId String // 下级
  superiorId    String // 上级
  // SOLID 附加实线 / DOTTED 虚线
  kind          String   @default("DOTTED")
  subordinate   Contact  @relation("LinkSub", fields: [subordinateId], references: [id], onDelete: Cascade)
  superior      Contact  @relation("LinkSup", fields: [superiorId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([subordinateId, superiorId])
  @@index([partnerId])
}

model Opportunity {
  id         String    @id @default(cuid())
  partnerId  String
  partner    Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name       String
  client     String?
  amount     String?
  stage      String    @default("需求诊断")
  nextStep   String?
  followUpAt DateTime?
  status     String    @default("ACTIVE") // ACTIVE / WON / LOST / PAUSED
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model TodoItem {
  id         String    @id @default(cuid())
  title      String
  detail     String?
  partnerId  String?
  partner    Partner?  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   User?     @relation(fields: [assigneeId], references: [id])
  dueDate    DateTime?
  priority   String    @default("MEDIUM") // HIGH / MEDIUM / LOW
  status     String    @default("OPEN") // OPEN / DONE / CANCELLED
  source     String    @default("MANUAL") // MANUAL / AI / SEED
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  doneAt     DateTime?
}

model TimelineEvent {
  id          String   @id @default(cuid())
  partnerId   String
  partner     Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  // NOTE / MEETING / CHAT_IMPORT / AI_SUMMARY / NEWS / SYSTEM / CHANGE
  type        String   @default("NOTE")
  title       String
  content     String?
  meta        String? // JSON：AI 审计信息（依据原文、变更明细等）
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

model Training {
  id          String    @id @default(cuid())
  partnerId   String
  partner     Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  person      String
  currentSkill String?
  targetCert  String?
  method      String?
  deadline    DateTime?
  status      String    @default("PLANNED") // PLANNED / IN_PROGRESS / DONE
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AiApiConfig {
  id          String              @id @default(cuid())
  name        String
  provider    String              @default("openai") // openai | volcengine
  baseUrl     String
  apiKey      String
  model       String
  extraConfig String? // JSON：火山引擎 Responses API 的 tools / instructions 等
  capabilities String? // JSON 数组：chat | vision | tools | json | reasoning
  dailyTokenLimit Int? // 每日总 Token 上限；超过后自动切换到其他启用模型。null/0 表示不限
  priority    Int                 @default(0) // 调度优先级：数字越大越先用（适合先用完免费额度）。能力不匹配时自动跳过
  enabled     Boolean             @default(true)
  isDefault   Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  tokenUsages AiTokenUsage[]
  dailyUsages AiDailyTokenUsage[]
}

model AiTokenUsage {
  id               String       @id @default(cuid())
  apiConfigId      String?
  apiConfig        AiApiConfig? @relation(fields: [apiConfigId], references: [id], onDelete: SetNull)
  bucketKey        String
  apiName          String
  feature          String
  model            String
  promptTokens     Int          @default(0)
  completionTokens Int          @default(0)
  totalTokens      Int          @default(0)
  status           String       @default("SUCCESS")
  error            String?
  userId           String?
  user             User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())

  @@index([apiConfigId, createdAt])
  @@index([bucketKey, createdAt])
  @@index([feature, createdAt])
}

model AiDailyTokenUsage {
  id               String       @id @default(cuid())
  apiConfigId      String?
  apiConfig        AiApiConfig? @relation(fields: [apiConfigId], references: [id], onDelete: SetNull)
  bucketKey        String
  apiName          String
  day              String
  promptTokens     Int          @default(0)
  completionTokens Int          @default(0)
  totalTokens      Int          @default(0)
  requestCount     Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([bucketKey, day])
  @@index([apiConfigId, day])
  @@index([day])
}

model Agent {
  id           String    @id @default(cuid())
  name         String
  icon         String    @default("🤖")
  description  String?
  instructions String // 系统提示词：这个 Agent 是谁、做什么
  skills       String // JSON 数组：启用的技能名
  trigger      String    @default("MANUAL") // MANUAL / SCHEDULE
  frequency    String? // HOURLY / DAILY / WEEKLY
  runHour      Int       @default(9) // DAILY/WEEKLY 的运行时刻（0-23）
  runWeekday   Int       @default(1) // WEEKLY 的星期（1=周一 ... 7=周日）
  nextRunAt    DateTime?
  scopeType    String    @default("ALL") // ALL / PARTNER
  partnerId    String?
  partner      Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  shared       Boolean   @default(true)
  enabled      Boolean   @default(true)
  webhookUrl   String?
  isTemplate   Boolean   @default(false) // 模板库条目，克隆使用
  createdById  String?
  createdBy    User?     @relation(fields: [createdById], references: [id])
  lastRunAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  runs         AgentRun[]
  skillLinks   AgentSkill[]
}

model AgentRun {
  id         String    @id @default(cuid())
  agentId    String
  agent      Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  status     String    @default("RUNNING") // RUNNING / SUCCESS / FAILED
  output     String? // Markdown 简报
  toolLog    String? // JSON：工具调用审计
  error      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  notifications Notification[]
  documents     Document[]
}

model Notification {
  id         String    @id @default(cuid())
  title      String
  content    String?
  agentRunId String?
  agentRun   AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  partnerId  String?
  proposal   String? // JSON：待人工确认的档案变更提案
  appliedAt  DateTime?
  readAt     DateTime?
  createdAt  DateTime  @default(now())
}

model Asset {
  id           String   @id @default(cuid())
  // FILE 上传文件 / LINK 云盘外链
  kind         String   @default("FILE")
  filename     String
  mimeType     String   @default("application/octet-stream")
  size         Int      @default(0)
  storageKey   String? // FILE 才有本地存储 key
  url          String? // LINK 的外部链接
  thumbnailUrl String? // 预览缩略图（OG 图或云盘缩略图）
  provider     String? // gdrive / dropbox / web 等
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
  materials    Material[]
  solutionLinks SolutionAsset[]
  documentLinks DocumentAsset[]
}

model Document {
  id             String   @id @default(cuid())
  title          String
  type           String   @default("CUSTOM")
  status         String   @default("DRAFT")
  content        String   @default("")
  partnerId      String?
  partner        Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  solutionId     String?
  solution       Solution? @relation(fields: [solutionId], references: [id], onDelete: SetNull)
  agentRunId     String?
  agentRun       AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  notificationId String?
  createdById    String?
  createdBy      User?    @relation(fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  assets         DocumentAsset[]
}

model DocumentAsset {
  documentId String
  assetId    String
  label      String?
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@id([documentId, assetId])
}

model Material {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("OTHER")
  body        String?
  assetId     String?
  asset       Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  tags        String?
  shared      Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KnowledgeArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  category    String   @default("COMPANY")
  content     String
  shared      Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Solution {
  id             String   @id @default(cuid())
  partnerId      String
  partner        Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name           String
  targetCustomer String?
  painPoint      String?
  fanruanOffer   String?
  partnerOffer   String?
  pricingModel   String?
  status         String   @default("DRAFT")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  assets         SolutionAsset[]
  documents      Document[]
}

model SolutionAsset {
  solutionId String
  assetId    String
  label      String?
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@id([solutionId, assetId])
}

model Skill {
  id          String   @id @default(cuid())
  name        String
  label       String
  description String?
  kind        String   @default("PROMPT")
  toolDef     String?
  promptBody  String?
  shared      Boolean  @default(false)
  isBuiltin   Boolean  @default(false)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  agentLinks  AgentSkill[]
}

model AgentSkill {
  agentId String
  skillId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  @@id([agentId, skillId])
}

// 用户个人 KMS（Confluence）访问令牌，每人一份
model UserKmsCredential {
  userId      String   @id
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  baseUrl     String   @default("https://kms.fineres.com")
  accessToken String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 团队级 KMS 回退令牌（用户未配置个人令牌时使用）
model SystemKmsCredential {
  id          String   @id @default("singleton")
  baseUrl     String   @default("https://kms.fineres.com")
  accessToken String
  updatedAt   DateTime @updatedAt
}

// 帆软 CRM 同步客户（com_id 为主键）
model CrmCustomer {
  id            String       @id
  name          String
  province      String?
  city          String?
  status        String?
  salesman      String?
  kpiContactDay DateTime?
  syncedAt      DateTime     @updatedAt
  contacts      CrmContact[]

  @@index([name])
  @@index([salesman])
}

// 帆软 CRM 同步联系人（cont_id 为主键）
model CrmContact {
  id         String      @id
  customerId String
  customer   CrmCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String?
  mobile     String?
  email      String?
  duty       String?
  recdate    DateTime?
  syncedAt   DateTime    @updatedAt

  @@index([customerId])
}

// CRM 数据同步日志
model CrmSyncLog {
  id            String   @id @default(cuid())
  status        String
  customerCount Int?
  contactCount  Int?
  durationMs    Int?
  error         String?
  createdAt     DateTime @default(now())
}
