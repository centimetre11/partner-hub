generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  name         String
  passwordHash String
  // SALES 销售 / PRESALES 售前 / ADMIN 管理员 / OTHER 其他
  role         String          @default("OTHER")
  createdAt    DateTime        @default(now())
  partners     Partner[]
  salesPartners    Partner[] @relation("PartnerSalesUser")
  presalesPartners Partner[] @relation("PartnerPresalesUser")
  todos        TodoItem[]
  events       TimelineEvent[]
  agents       Agent[]
  assets       Asset[]
  documents    Document[]
  materials    Material[]
  knowledgeArticles KnowledgeArticle[]
  faqEntries        FaqEntry[]
  taxonomyOptions   TaxonomyOption[]
  skills       Skill[]
  aiTokenUsages AiTokenUsage[]
  aiConversationLogs AiConversationLog[]
  systemEventLogs SystemEventLog[] @relation("SystemEventActor")
  kmsCredential UserKmsCredential?
  googleMeetCredential UserGoogleMeetCredential?
  businessRecords BusinessRecord[]
  feedbackSubmissions FeedbackSubmission[]
  ownedCustomers   Customer[] @relation("CustomerOwner")
  presalesCustomers Customer[] @relation("CustomerPresalesUser")
  createdCustomers Customer[] @relation("CustomerCreatedBy")
  ownedProjects    Project[]  @relation("ProjectOwner")
  projectWorkLogs  ProjectWorkLog[]
  createdContracts Contract[] @relation("ContractCreatedBy")
  crmSalesmanName String? // 帆软 CRM 销售英文名，对应 com_salesman（如 Fay.Wen）
  wecomUserId     String? @unique // 企业微信成员 userid，用于识别发消息者与 @ 提醒
  wecomDisplayName String? @unique // 企微群聊显示名（如 saber-陈敏），userid 不可用时的兜底匹配
  // 异步通知语言偏好：zh 中文 / en 英文；null 表示跟随团队周报默认
  reportLocale    String?
  wecomBindCode String? // 企微一键绑定码（6 位，短期有效）
  wecomBindCodeExpiresAt DateTime?
  partnerReviewMeetings PartnerReviewMeeting[]
  weeklyReportSnapshots WeeklyReportSnapshot[]
}

model Partner {
  id               String   @id @default(cuid())
  name             String   @unique
  // PROSPECT 候选 / ACTIVE 正式 / ARCHIVED 归档
  status           String   @default("PROSPECT")
  // 归档前的状态，用于恢复时原样还原
  prevStatus       String?
  // NEW 新候选 / ADVANCING 推进中 / WATCHING 观察 / DROPPED 放弃
  poolFlag         String   @default("NEW")
  // PURE_DATA / POWER_BI / TABLEAU / QLIK / IT_INTEGRATOR / OTHER
  category         String   @default("OTHER")
  industries       String?  // JSON 数组，主攻行业多选
  capabilities     String?  // JSON 数组，能力标签多选（CONSULTING / IMPLEMENTATION / …）
  // DATA_NATIVE / BI_MIGRATOR / IT_INTEGRATOR / IOT_INTEGRATOR / SALES_AGENT / SHELL_DATA / OTHER
  partnerArchetype String?
  // IOT_DASH / APP_REPORT / CLOUD_APP / DATA_BI / BI_COMPLEMENT / OEM_EMBED / GOV_BID
  valuePattern     String?
  valuePartnerOffer String? // 伙伴提供什么
  valueFanruanOffer String? // 帆软提供什么
  valueCustomerOutcome String? // 客户得到什么
  dedicatedHeadcount String? // 专职做帆软/数据业务人数
  tier             String? // A / B / C
  city             String?
  country          String?
  headcount        String?
  website          String?
  companyType      String?
  coreBusiness     String?
  capability       String?
  knownClients     String?
  partnerAnnualRevenue String? // 伙伴自身年营收（估算）
  partnerDealsPerYear  String? // 一年约几单
  estimatedAnnualValue String? // 预估为帆软一年带来多少
  certLevel        String?
  currentTools     String?
  keyDifferentiator String?
  playbook         String?
  pitch            String?
  bestChannel      String?
  fitScore         Int?
  priority         String? // P0 / P1 / P2 / P3
  aiVerified       String? // VERIFIED / PARTIAL / UNKNOWN
  manualChecked    Boolean  @default(false)
  monitorDims      String? // JSON 数组：舆情监控勾选的维度
  statusOverview   String? // JSON：伙伴状态总览维度手动覆盖 { dim: { level, note, updatedAt, updatedById } }
  kmsRootPath      String? // KMS 主目录，手动填写
  gdriveFolderUrl  String? // 该伙伴材料归档的 Google Drive 子目录链接
  crmCustomerId    String? // 帆软 CRM 客户 ID
  wecomChatBindCode          String?
  wecomChatBindCodeExpiresAt DateTime?
  pipelineStage    Int      @default(1) // 1-3 三类：初步接触 / 实质推进 / 系统合作
  ownerId          String?
  owner            User?    @relation(fields: [ownerId], references: [id])
  salesUserId      String?
  salesUser        User?    @relation("PartnerSalesUser", fields: [salesUserId], references: [id])
  presalesUserId   String?
  presalesUser     User?    @relation("PartnerPresalesUser", fields: [presalesUserId], references: [id])
  promotedAt       DateTime?
  poolContactedAt  DateTime? // 候选审阅：首次标记「已联络」
  notes            String?
  // Distributor：显式勾选后才可挂子伙伴（仅两级）
  isDistributor    Boolean  @default(false)
  parentId         String?
  parent           Partner?  @relation("PartnerHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children         Partner[] @relation("PartnerHierarchy")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  contacts      Contact[]
  contactLinks  ContactLink[]
  opportunities Opportunity[]
  projects      Project[]
  todos         TodoItem[]
  events        TimelineEvent[]
  trainings     Training[]
  agents        Agent[]
  solutions     Solution[]
  documents     Document[]
  monitorSources MonitorSource[]
  monitorItems  MonitorItem[]
  wecomChat     WecomChat?
  businessRecords BusinessRecord[]
  aiConversationLogs AiConversationLog[]
  customers     Customer[] // 遗留：旧的一对多绑定，迁移后改用 customerLinks
  customerLinks CustomerPartner[]
  assets        Asset[]
  reviewItems   PartnerReviewItem[]
  contracts     Contract[]

  @@index([parentId])
  @@index([isDistributor])
}

// 客户：伙伴服务的终端客户（手动维护，可归属到某个伙伴）
model Customer {
  id           String   @id @default(cuid())
  name         String
  // ACTIVE 合作中 / PROSPECT 潜在 / INACTIVE 已停止
  status       String   @default("ACTIVE")
  industry     String?  // 行业（自由文本）
  // 细分客群 taxonomy codes — CUSTOMER_SEGMENT / BUYING_TRIGGER / ENTRY_PATH / ICP_TIER
  customerSegment String?
  buyingTrigger   String?
  entryPath       String?
  icpTier         String?
  city         String?
  country      String?
  website      String?
  scale        String?  // 规模（人数/营收等，自由文本）
  contactName  String?  // 主联系人
  contactTitle String?  // 主联系人职务
  contactPhone String?
  contactEmail String?
  notes        String?
  // 跟单五问（STOCK）：S 现状 / T 痛点 / O 核心需求 / C 预算 / K 关键
  q5Situation  String? // S = Situation 问现状（了解客户当前情况）
  q5Trouble    String? // T = Trouble 问痛点（挖掘真实困扰难题）
  q5Order      String? // O = Order 问核心需求（采购 / 合作需求）
  q5Cost       String? // C = Cost 问预算（成本 & 价格预期）
  q5Key        String? // K = Key 问关键（决策人、交期、合作条件）
  // 遗留字段：旧的一对多绑定（一个客户至多一个伙伴），迁移后改用 partnerLinks，仅保留供一次性回填
  partnerId    String?
  partner      Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  // 多对多绑定：一个客户可绑定多个伙伴
  partnerLinks CustomerPartner[]
  // 记录性质：SERVED_BY 伙伴服务的终端客户 / SELF 该客户即伙伴本身（伙伴自营影子档案，与单一伙伴一一对应）
  partnerRelation String? @default("SERVED_BY")
  // 帆软集成三连接
  kmsRootPath   String? // KMS 主目录
  gdriveFolderUrl String? // 该客户材料归档的 Google Drive 子目录链接
  crmCustomerId String? // 帆软 CRM 客户 ID
  creditCode    String? // 统一社会信用代码（Moss 主体锁定）
  mossSnapshot  Json?   // 最近一次 Moss 背调结构化快照
  mossSyncedAt  DateTime?
  wecomChatBindCode          String?
  wecomChatBindCodeExpiresAt DateTime?
  // 销售负责人 / 售前负责人
  ownerId      String?
  owner        User?    @relation("CustomerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  presalesUserId String?
  presalesUser   User?  @relation("CustomerPresalesUser", fields: [presalesUserId], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    User?    @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contacts        Contact[]
  contactLinks    ContactLink[]
  opportunities   Opportunity[]
  projects        Project[]
  contracts       Contract[]
  todos           TodoItem[]
  events          TimelineEvent[]
  businessRecords BusinessRecord[]
  wecomChat       WecomChat?
  assets          Asset[]
  trainings       Training[]

  @@index([partnerId])
  @@index([name])
  @@index([status])
  @@index([customerSegment])
  @@index([icpTier])
}

// 客户↔伙伴 多对多绑定。relation：SERVED_BY 伙伴服务的终端客户 / SELF 该客户即伙伴本身
model CustomerPartner {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  partnerId  String
  partner    Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  relation   String   @default("SERVED_BY") // SERVED_BY / SELF
  createdAt  DateTime @default(now())

  @@unique([customerId, partnerId])
  @@index([partnerId])
  @@index([customerId])
}

// 商务记录：伙伴关键进展（双写活动线 MILESTONE）
model BusinessRecord {
  id              String    @id @default(cuid())
  partnerId       String?
  partner         Partner?  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  category        String    // VISIT / TRAINING / NEGOTIATION / DELIVERY / RELATIONSHIP / OTHER
  title           String
  content         String?
  crmTraceNature  String?   // 现场 | 非现场（CRM KPI）
  crmTraceAction  String?   // CRM 商务行为
  occurredAt      DateTime  @default(now())
  contactId       String?
  contact         Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  timelineEventId String?   @unique
  sourceTodoId    String?
  source          String    @default("MANUAL") // MANUAL / TODO / RELATIONSHIP_TAB
  createdById     String?
  createdBy       User?     @relation(fields: [createdById], references: [id])
  crmTraceId      String?
  crmSyncedAt     DateTime?
  crmSyncStatus   String?   // SYNCED | FAILED | SKIPPED | PARTIAL
  crmSyncError    String?   // failure or skip reason
  crmRecorderUserIds String? // JSON array of Hub user IDs credited in CRM
  createdAt       DateTime  @default(now())

  @@index([partnerId, occurredAt])
  @@index([customerId, occurredAt])
}

// 企业微信会话（群聊/单聊），可与伙伴绑定用于主动推送
model WecomChat {
  id         String   @id @default(cuid())
  chatId     String   @unique
  chatType   String   @default("group") // group | single
  label      String?
  partnerId  String?  @unique
  partner    Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  customerId String?  @unique
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 企微主动推送队列（由 wecom-bot 容器消费）
model WecomPushJob {
  id        String    @id @default(cuid())
  chatId    String
  content   String
  status    String    @default("PENDING") // PENDING | SENT | FAILED
  error     String?
  createdAt DateTime  @default(now())
  sentAt    DateTime?

  @@index([status, createdAt])
}

// 维度库：伙伴类型 / 行业 / 价值模式 / 竞品基因 的可扩展选项
model TaxonomyOption {
  id          String   @id @default(cuid())
  dimension   String   // ARCHETYPE | INDUSTRY | VALUE_PATTERN | CATEGORY | CAPABILITY
  code        String
  label       String
  description String?
  sortOrder   Int      @default(0)
  isBuiltin   Boolean  @default(false)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dimension, code])
  @@index([dimension])
}

// 舆情监控：自定义监控链接源（领英/Facebook 主页、官网、新闻源等）
model MonitorSource {
  id           String   @id @default(cuid())
  partnerId    String
  partner      Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  label        String
  url          String
  // LINKEDIN / FACEBOOK / X / WEBSITE / NEWS / CUSTOM
  sourceType   String   @default("CUSTOM")
  domain       String? // 用于 site: 过滤
  title        String? // 链接预览标题
  thumbnailUrl String?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([partnerId])
}

// 舆情监控：扫描并经 AI 分类后的舆情条目
model MonitorItem {
  id          String    @id @default(cuid())
  partnerId   String
  partner     Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  // NEWS / PEOPLE / HIRING / DEALS / FUNDING / COMPETITOR / SOCIAL / REPUTATION / EVENTS / ALLIANCE / RISK
  dimension   String    @default("NEWS")
  // POSITIVE / NEUTRAL / NEGATIVE / RISK
  sentiment   String    @default("NEUTRAL")
  title       String
  summary     String?
  url         String?
  sourceName  String?
  sourceType  String    @default("web") // web / linkedin / custom
  publishedAt DateTime?
  dedupeKey   String
  status      String    @default("NEW") // NEW / ARCHIVED
  createdAt   DateTime  @default(now())

  @@unique([partnerId, dedupeKey])
  @@index([partnerId])
}

model Contact {
  id          String    @id @default(cuid())
  partnerId   String?
  partner     Partner?  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name        String
  // APPROVER(A审批者) / DECISION_MAKER(D决策者) / SUPPORTER(S支持者) / EVALUATOR(E评估者) / INFLUENCER(I影响者)
  role        String    @default("INFLUENCER")
  title       String?
  department  String? // 部门
  attitude    Int       @default(0) // 3教练 / 2支持并排他 / 1支持不排他 / 0未接触或中立 / -1反对
  reportsToId String? // 汇报上级（主汇报实线）
  reportsTo   Contact?  @relation("ContactReports", fields: [reportsToId], references: [id], onDelete: SetNull)
  reports     Contact[] @relation("ContactReports")
  x           Float? // 权力地图手动摆放坐标（null = 自动布局）
  y           Float?
  linksAsSub  ContactLink[] @relation("LinkSub") // 作为下级的附加汇报线
  linksAsSup  ContactLink[] @relation("LinkSup") // 作为上级的附加汇报线
  contactInfo String?
  approach    String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  businessRecords BusinessRecord[]

  @@index([partnerId])
  @@index([customerId])
}

// 附加汇报线（虚线/双线汇报）。主汇报实线仍走 Contact.reportsToId
model ContactLink {
  id            String   @id @default(cuid())
  partnerId     String?
  partner       Partner? @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  subordinateId String // 下级
  superiorId    String // 上级
  // SOLID 附加实线 / DOTTED 虚线
  kind          String   @default("DOTTED")
  subordinate   Contact  @relation("LinkSub", fields: [subordinateId], references: [id], onDelete: Cascade)
  superior      Contact  @relation("LinkSup", fields: [superiorId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([subordinateId, superiorId])
  @@index([partnerId])
  @@index([customerId])
}

model Opportunity {
  id         String    @id @default(cuid())
  // 商机以客户为主体；伙伴为可选（带单/交付方）
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  partnerId  String?
  partner    Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  name       String
  client     String?
  amount     String?
  // JSON array of process tag codes, e.g. ["QUOTE","BID_DOC"]; see opportunity-process-tags.ts
  stage      String    @default("[\"DISCOVERY\"]")
  // Single process tag code for next focus, e.g. "BID"; same code set as stage
  nextStep   String?
  followUpAt DateTime?
  status     String    @default("P20") // P20 / P50 / P80 / WON / LOST / PAUSED（旧 ACTIVE 视为 P20）
  // 成交类型（赢单后区分是否含交付项目）：PROJECT 项目型（可转项目）/ PRODUCT 纯产品型（无项目）。null 未定
  dealType   String?
  // 赢单/丢单复盘 — WIN_FACTOR / LOSS_REASON taxonomy codes；customerSegment 成交时快照
  customerSegment String?
  winFactor       String?
  lossReason      String?
  notes      String?
  // 赢单后转化生成的合作项目（一对一）
  project    Project?  @relation("OpportunityProject")
  contracts  Contract[]
  todos      TodoItem[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([customerId])
  @@index([partnerId])
}

// 已合作项目：机会赢单后转化生成的交付/合作项目（以客户为主体）
model Project {
  id                  String       @id @default(cuid())
  customerId          String
  customer            Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  // 可选交付方/带单伙伴
  partnerId           String?
  partner             Partner?     @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  name                String
  // 来源机会（一对一回溯），赢单转化时写入
  sourceOpportunityId String?      @unique
  sourceOpportunity   Opportunity? @relation("OpportunityProject", fields: [sourceOpportunityId], references: [id], onDelete: SetNull)
  // KICKOFF 启动 / IMPLEMENT 实施 / ACCEPTANCE 验收 / GOLIVE 上线 / MAINTENANCE 运维
  phase               String       @default("KICKOFF")
  // ACTIVE 进行中 / ON_HOLD 暂停 / DONE 已完成 / CLOSED 已关闭
  status              String       @default("ACTIVE")
  amount              String?
  startDate           DateTime?
  endDate             DateTime?
  ownerId             String?
  owner               User?        @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  todos               TodoItem[]
  events              TimelineEvent[]
  workLogs            ProjectWorkLog[]
  contracts           Contract[]

  @@index([customerId])
  @@index([partnerId])
}

// 合同：客户已签约的商务合同（订阅 / 微宝 / 买断）
// 买断商业规则：产品合同含一定比例微宝（如 15%/20%）；首年微宝随产品打包，次年起单独付微宝。订阅无此逻辑。
model Contract {
  id            String    @id @default(cuid())
  customerId    String
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  // 可选：经由渠道伙伴
  partnerId     String?
  partner       Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  // 可选：来源商机 / 关联交付项目
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  // 微宝续约可挂回买断母合同（次年单独付微宝）
  parentContractId String?
  parentContract   Contract?  @relation("ContractWeibaoChain", fields: [parentContractId], references: [id], onDelete: SetNull)
  childContracts   Contract[] @relation("ContractWeibaoChain")
  name          String
  // SUBSCRIPTION 订阅 / MAINTENANCE 微宝 / BUYOUT 买断
  contractType  String
  // DRAFT 草稿 / ACTIVE 生效 / EXPIRED 已到期 / CANCELLED 已取消 / RENEWED 已续约（归档）
  status        String    @default("ACTIVE")
  amount        String?
  startDate     DateTime?
  endDate       DateTime? // 买断可为空（永久授权）
  renewsAt      DateTime? // 下次续约/续费日（订阅、微宝常用）
  // MONTHLY / QUARTERLY / YEARLY / OTHER；买断通常为空
  billingCycle  String?
  // 买断专用：微宝占产品合同金额比例（如 15、20）；订阅应为 null
  weibaoRatePct Int?
  // 买断专用：首年微宝是否已含在产品买断价中（true=首年打包，次年起单独微宝合同）
  weibaoIncludedY1 Boolean @default(false)
  notes         String?
  createdById   String?
  createdBy     User?     @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([customerId])
  @@index([partnerId])
  @@index([opportunityId])
  @@index([projectId])
  @@index([parentContractId])
  @@index([contractType])
  @@index([status])
  @@index([endDate])
  @@index([renewsAt])
}

// 项目工作记录：按条记录交付进展，供周报汇总
model ProjectWorkLog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([authorId])
  @@index([createdAt])
}

model TodoItem {
  id         String    @id @default(cuid())
  title      String
  detail     String?
  partnerId  String?
  partner    Partner?  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assigneeId String?
  assignee   User?     @relation(fields: [assigneeId], references: [id])
  dueDate    DateTime?
  priority   String    @default("MEDIUM") // HIGH / MEDIUM / LOW
  status     String    @default("OPEN") // OPEN / DONE / CANCELLED
  source     String    @default("MANUAL") // MANUAL / AI / SEED
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  doneAt     DateTime?

  @@index([opportunityId])
  @@index([projectId])
}

model TimelineEvent {
  id          String   @id @default(cuid())
  partnerId   String?
  partner     Partner? @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // NOTE / MEETING / CHAT_IMPORT / AI_SUMMARY / NEWS / SYSTEM / CHANGE
  type        String   @default("NOTE")
  title       String
  content     String?
  meta        String? // JSON：AI 审计信息（依据原文、变更明细等）
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([partnerId])
  @@index([customerId])
  @@index([projectId])
}

model Training {
  id          String    @id @default(cuid())
  partnerId   String?
  partner     Partner?  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  person      String
  currentSkill String?
  targetCert  String?
  method      String?
  deadline    DateTime?
  status      String    @default("PLANNED") // PLANNED / IN_PROGRESS / DONE
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([partnerId])
  @@index([customerId])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AiApiConfig {
  id          String              @id @default(cuid())
  name        String
  provider    String              @default("openai") // openai | volcengine
  baseUrl     String
  apiKey      String
  model       String
  extraConfig String? // JSON：火山引擎 Responses API 的 tools / instructions 等
  capabilities String? // JSON 数组：chat | vision | tools | json | reasoning
  dailyTokenLimit Int? // 每日总 Token 上限；超过后自动切换到其他启用模型。null/0 表示不限
  priority    Int                 @default(0) // 调度优先级：数字越大越先用（适合先用完免费额度）。能力不匹配时自动跳过
  enabled     Boolean             @default(true)
  isDefault   Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  tokenUsages AiTokenUsage[]
  dailyUsages AiDailyTokenUsage[]
  sceneModels LlmSceneModel[]
}

/// 场景模型分配：把模型按顺序加入某个场景（线索研究 / 快速交互 / 建档 / 图片 / 默认）。
/// 选中场景时按 order 依次尝试，额度用尽自动切下一个；全部用尽后回退到「默认」场景再到全部启用模型。
model LlmSceneModel {
  id          String      @id @default(cuid())
  scene       String // lead_research | fast | profiling | vision | default
  apiConfigId String
  apiConfig   AiApiConfig @relation(fields: [apiConfigId], references: [id], onDelete: Cascade)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())

  @@unique([scene, apiConfigId])
  @@index([scene, order])
}

model AiTokenUsage {
  id               String       @id @default(cuid())
  apiConfigId      String?
  apiConfig        AiApiConfig? @relation(fields: [apiConfigId], references: [id], onDelete: SetNull)
  bucketKey        String
  apiName          String
  feature          String
  model            String
  promptTokens     Int          @default(0)
  completionTokens Int          @default(0)
  totalTokens      Int          @default(0)
  status           String       @default("SUCCESS")
  error            String?
  userId           String?
  user             User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())

  @@index([apiConfigId, createdAt])
  @@index([bucketKey, createdAt])
  @@index([feature, createdAt])
}

model AiDailyTokenUsage {
  id               String       @id @default(cuid())
  apiConfigId      String?
  apiConfig        AiApiConfig? @relation(fields: [apiConfigId], references: [id], onDelete: SetNull)
  bucketKey        String
  apiName          String
  day              String
  promptTokens     Int          @default(0)
  completionTokens Int          @default(0)
  totalTokens      Int          @default(0)
  requestCount     Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([bucketKey, day])
  @@index([apiConfigId, day])
  @@index([day])
}

model Agent {
  id           String    @id @default(cuid())
  name         String
  icon         String    @default("🤖")
  description  String?
  instructions String // 系统提示词：这个 Agent 是谁、做什么
  skills       String // JSON 数组：启用的技能名
  trigger      String    @default("MANUAL") // MANUAL / SCHEDULE
  frequency    String? // HOURLY / DAILY / WEEKLY
  runHour      Int       @default(9) // DAILY/WEEKLY 的运行时刻（0-23）
  runWeekday   Int       @default(1) // WEEKLY 的星期（1=周一 ... 7=周日）
  nextRunAt    DateTime?
  scopeType    String    @default("ALL") // ALL / PARTNER
  partnerId    String?
  partner      Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  shared       Boolean   @default(true)
  enabled      Boolean   @default(true)
  webhookUrl       String?
  pushEmailTo      String? // 默认邮件推送收件人（send_email）
  pushWecomAppTo   String? // 企微应用私信收件人（Hub 邮箱逗号分隔，或 @assignees）
  wecomPushChatId  String? // 运行完成后推送到指定企微 chatId
  isTemplate       Boolean   @default(false) // 模板库条目，克隆使用
  isAutomation     Boolean   @default(false) // 自动化管道（区别于交互式 Agent）
  slug             String?   @unique // 自动化英文标识符
  cronExpr         String?   // Cron 表达式，如 0 9 * * *
  timezone         String?   @default("Asia/Shanghai")
  validityDays     Int       @default(7) // 任务有效期（天）
  variables        String?   // JSON：[{ key, value, label? }]
  queryConfig      String?   // JSON：结构化查询配置 AutomationQuery（待办/商机/AI 兜底）
  maxIterations    Int       @default(30) // 单次执行最大迭代次数
  timeoutMinutes   Int       @default(60) // 超时时间（分钟）
  notifyOnSuccess  Boolean   @default(true)
  notifyOnFailure  Boolean   @default(true)
  createdById  String?
  createdBy    User?     @relation(fields: [createdById], references: [id])
  lastRunAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  runs         AgentRun[]
  skillLinks   AgentSkill[]
}

model AgentRun {
  id         String    @id @default(cuid())
  agentId    String
  agent      Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  status     String    @default("RUNNING") // RUNNING / SUCCESS / FAILED
  output     String? // Markdown 简报
  toolLog    String? // JSON：工具调用审计
  error      String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  notifications Notification[]
  documents     Document[]
  weeklyReportSnapshots WeeklyReportSnapshot[]
}

// 团队周报历史快照（个人邮件 / 管理者汇总）
model WeeklyReportSnapshot {
  id          String    @id @default(cuid())
  // PERSONAL | MANAGER_DIGEST
  kind        String
  weekLabel   String
  windowStart DateTime
  windowEnd   DateTime
  locale      String    @default("zh")
  subject     String
  html        String
  text        String?
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName    String?
  // SCHEDULED | MANUAL | TEST
  source      String    @default("SCHEDULED")
  agentRunId  String?
  agentRun    AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([weekLabel])
  @@index([kind, createdAt])
  @@index([userId, createdAt])
  @@index([agentRunId])
}

model Notification {
  id         String    @id @default(cuid())
  title      String
  content    String?
  agentRunId String?
  agentRun   AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  partnerId  String?
  proposal   String? // JSON：待人工确认的档案变更提案
  appliedAt  DateTime?
  readAt     DateTime?
  createdAt  DateTime  @default(now())
}

model Asset {
  id           String   @id @default(cuid())
  // FILE 上传文件 / LINK 云盘外链
  kind         String   @default("FILE")
  filename     String
  mimeType     String   @default("application/octet-stream")
  size         Int      @default(0)
  storageKey   String? // FILE 才有本地存储 key
  url          String? // LINK 的外部链接
  thumbnailUrl String? // 预览缩略图（OG 图或云盘缩略图）
  provider     String? // gdrive / dropbox / web 等
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  // 按客户/伙伴归档的材料（直传谷歌云后落库的 LINK Asset，至多归属其一）
  partnerId    String?
  partner      Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  materials    Material[]
  solutionLinks SolutionAsset[]
  documentLinks DocumentAsset[]
  feedbackLinks FeedbackAsset[]

  @@index([partnerId])
  @@index([customerId])
}

// 用户提交的需求与问题
model FeedbackSubmission {
  id          String   @id @default(cuid())
  // REQUIREMENT 需求 / ISSUE 问题 / OTHER 其他
  type        String
  title       String
  description String?
  // OPEN 待处理 / IN_PROGRESS 处理中 / RESOLVED 已解决 / CLOSED 已关闭
  status      String   @default("OPEN")
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assets      FeedbackAsset[]
}

model FeedbackAsset {
  feedbackId String
  assetId    String
  feedback   FeedbackSubmission @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  asset      Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([feedbackId, assetId])
}

model Document {
  id             String   @id @default(cuid())
  title          String
  type           String   @default("CUSTOM")
  status         String   @default("DRAFT")
  content        String   @default("")
  partnerId      String?
  partner        Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  solutionId     String?
  solution       Solution? @relation(fields: [solutionId], references: [id], onDelete: SetNull)
  agentRunId     String?
  agentRun       AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  notificationId String?
  createdById    String?
  createdBy      User?    @relation(fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  assets         DocumentAsset[]
}

model DocumentAsset {
  documentId String
  assetId    String
  label      String?
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@id([documentId, assetId])
}

model Material {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("OTHER")
  body        String?
  assetId     String?
  asset       Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  tags        String?
  shared      Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KnowledgeArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  category    String   @default("COMPANY")
  content     String
  shared      Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FaqEntry {
  id             String   @id @default(cuid())
  // 别人常问我们的问题，例如「你们产品的优势是什么」「你们和 XX 的区别是什么」
  question       String
  // 团队沉淀的标准答案（Markdown），所有人可一起补充更新
  answer         String   @default("")
  // 分类：PRODUCT_ADVANTAGE 产品优势 / COMPETITOR 竞品对比 / PRICING 报价商务 ...
  category       String   @default("PRODUCT_ADVANTAGE")
  createdById    String?
  createdBy      User?    @relation(fields: [createdById], references: [id])
  // 最近更新者姓名（去归一化，便于「大家一起更新」的署名展示）
  lastEditorName String?
  // 认证：管理员认证后该问答成为「官方」答案
  verified       Boolean  @default(false)
  verifiedByName String?
  verifiedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Solution {
  id             String   @id @default(cuid())
  partnerId      String
  partner        Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name           String
  targetCustomer String?
  painPoint      String?
  fanruanOffer   String?
  partnerOffer   String?
  pricingModel   String?
  status         String   @default("DRAFT")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  assets         SolutionAsset[]
  documents      Document[]
}

model SolutionAsset {
  solutionId String
  assetId    String
  label      String?
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  @@id([solutionId, assetId])
}

model Skill {
  id          String   @id @default(cuid())
  name        String
  label       String
  description String?
  kind        String   @default("PROMPT")
  toolDef     String?
  promptBody  String?
  shared      Boolean  @default(false)
  isBuiltin   Boolean  @default(false)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  agentLinks  AgentSkill[]
}

model AgentSkill {
  agentId String
  skillId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  @@id([agentId, skillId])
}

// 用户个人 Google Meet 授权（每人独立 refresh_token，与团队 Drive 上传隔离）
model UserGoogleMeetCredential {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleEmail  String?
  refreshToken String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 用户个人 KMS（Confluence）访问令牌，每人一份
model UserKmsCredential {
  userId      String   @id
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  baseUrl     String   @default("https://kms.fineres.com")
  accessToken String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 团队级 KMS 回退令牌（用户未配置个人令牌时使用）
model SystemKmsCredential {
  id          String   @id @default("singleton")
  baseUrl     String   @default("https://kms.fineres.com")
  accessToken String
  updatedAt   DateTime @updatedAt
}

// 团队级 Know-how 知识库检索 API 令牌
model SystemKnowhowCredential {
  id        String   @id @default("singleton")
  baseUrl   String   @default("https://digitchat.fanruan.com/dataset")
  apiKey    String
  updatedAt DateTime @updatedAt
}

// 团队邮件服务（QQ 邮箱 SMTP 等）
model SystemEmailConfig {
  id         String   @id @default("singleton")
  smtpHost   String   @default("smtp.qq.com")
  smtpPort   Int      @default(465)
  smtpSecure Boolean  @default(true)
  fromEmail  String
  fromName   String?
  authCode   String
  updatedAt  DateTime @updatedAt
}

// 团队弹药库配置（Google 云盘文件夹 + KMS 页面地址）
model SystemAmmoConfig {
  id                   String   @id @default("singleton")
  gdriveFolderUrl      String?
  gdriveServiceAccount String?
  kmsPageUrls          String?
  // Google OAuth 上传账号（真人账号授权一次，用于写入/上传到 Drive）
  gdriveOauthClientId     String?
  gdriveOauthClientSecret String?
  gdriveOauthRefreshToken String?
  gdriveUploaderEmail     String?
  updatedAt            DateTime @updatedAt
}

// 帆软 CRM 同步客户（com_id 为主键）
model CrmCustomer {
  id            String       @id
  name          String
  province      String?
  city          String?
  status        String?
  salesman      String?
  presales      String?
  projectManager String?
  kpiContactDay DateTime?
  syncedAt      DateTime     @updatedAt
  contacts      CrmContact[]

  @@index([name])
  @@index([salesman])
  @@index([presales])
  @@index([projectManager])
}

// 帆软 CRM 同步联系人（cont_id 为主键）
model CrmContact {
  id         String      @id
  customerId String
  customer   CrmCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String?
  mobile     String?
  email      String?
  duty       String?
  recdate    DateTime?
  syncedAt   DateTime    @updatedAt

  @@index([customerId])
}

// AI 对话记录（问题、回复、操作者、渠道等）
model AiConversationLog {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel        String   @default("WEB") // WEB | WECOM
  feature        String
  mode           String?
  userMessage    String
  assistantReply String?
  partnerId      String?
  partner        Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  status         String   @default("SUCCESS") // SUCCESS | FAILED
  error          String?
  durationMs     Int?
  meta           String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([channel, createdAt])
  @@index([feature, createdAt])
}

// 系统事件埋点（登录、建档、同步、配置变更等）
model SystemEventLog {
  id          String   @id @default(cuid())
  category    String
  action      String
  actorId     String?
  actor       User?    @relation("SystemEventActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorLabel  String?
  targetType  String?
  targetId    String?
  targetLabel String?
  summary     String?
  detail      String?
  meta        String?
  status      String   @default("SUCCESS")
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([category, createdAt])
  @@index([action, createdAt])
  @@index([actorId, createdAt])
}

// CRM 数据同步日志
model CrmSyncLog {
  id            String   @id @default(cuid())
  status        String
  customerCount Int?
  contactCount  Int?
  durationMs    Int?
  error         String?
  createdAt     DateTime @default(now())
}

// 帆软 CRM 线索（clue_id 为主键），每天利雅得 05:00 全量拉取 2026 年线索后整表替换
model CrmLead {
  id           String    @id // clue_id
  companyId    String? // com_id
  name         String? // com_name，公司名称/线索公司名称
  status       String? // com_status，线索状态（含是否培育）
  province     String? // com_province
  countryCn    String? // cou_CN_name
  city         String? // com_city
  region       String? // reg
  zone         String? // zone
  rank         String? // com_rank
  source       String? // com_source
  sourceDetail String? // source
  tags         String? // tags
  sdrState     String? // sdr_state
  phone        String? // actphone
  contName     String? // cont_name
  contEmail    String? // cont_email
  contDuty     String? // cont_duty
  salesman     String? // com_salesman
  typeDetail   String? // typedetail
  overseaAgent String? // com_oversea_agent
  detail       String? // detail，商务记录2
  traceDetail  String? // trace_detail，商务记录1
  recdate      DateTime? // com_recdate，KPI 开始时间（亦用于 2026 过滤）
  contRecdate  DateTime? // cont_recdate
  jzDate       DateTime? // jz_date，KPI 截止时间
  syncedAt     DateTime  @updatedAt

  @@index([salesman])
  @@index([status])
  @@index([rank])
  @@index([recdate])
  @@index([jzDate])
}

// 线索联网研究结果（按 clue_id 持久化，不受 nightly 整表替换影响）
model CrmLeadResearch {
  id            String   @id @default(cuid())
  leadId        String   @unique // clue_id
  summary       String // Markdown summary for display
  resultJson    String // Structured JSON
  searchQuery   String?
  searchBackend String?
  modelUsed     String?
  rawChars      Int?
  status        String   @default("done") // done | error
  error         String?
  researchedAt  DateTime @default(now())
  researchedBy  String?

  @@index([researchedAt])
}

// CRM 线索同步日志
model LeadsSyncLog {
  id         String   @id @default(cuid())
  status     String
  leadCount  Int?
  durationMs Int?
  error      String?
  createdAt  DateTime @default(now())
}

// 钉钉开放平台凭证（A1 录音 / 钉盘 / 事件回调）
model SystemDingTalkConfig {
  id        String   @id @default("singleton")
  corpId    String?
  appKey    String
  appSecret String
  // 事件订阅加解密（HTTP 回调）
  token     String?
  aesKey    String?
  agentId   String? // 可选：工作通知 / 互动卡片
  // A1 JSAPI startDingerRecord 的录音模板 ID（钉钉客户端内一键开录）
  dingerTemplateId String?
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// 自研录音 / Whisper 识别优化（热词、纠偏、近实时）
model SystemAsrConfig {
  id                        String   @id @default("singleton")
  /// 会中分片近实时转写
  realtimeEnabled           Boolean  @default(true)
  /// 分片秒数（8–30）
  chunkSeconds              Int      @default(12)
  language                  String   @default("zh")
  /// 追加到 Whisper initial_prompt 的场景说明
  basePrompt                String?
  /// 热词，每行一个
  hotwords                  String?
  /// 纠偏规则，每行：错写=>正确
  correctionRules           String?
  /// 会后整段转写是否再用 LLM 按伙伴名纠偏
  llmCorrectEnabled         Boolean  @default(true)
  /// prompt 是否自动拼入本场伙伴名
  includePartnerNames       Boolean  @default(true)
  updatedAt                 DateTime @updatedAt
}

// 开会过伙伴：一场内部评审会
model PartnerReviewMeeting {
  id                     String   @id @default(cuid())
  title                  String
  // DRAFT | PREP | LIVE | PROCESSING | DONE
  status                 String   @default("DRAFT")
  scheduledAt            DateTime?
  startedAt              DateTime?
  endedAt                DateTime?
  createdById            String
  createdBy              User     @relation(fields: [createdById], references: [id])
  dingtalkRecordId       String?
  dingtalkConferenceId   String?
  dingtalkSpaceId        String?
  dingtalkFileId         String?
  transcriptText         String?
  /// 带句子 startTime 的结构化转写 JSON（TimedTranscriptDoc）
  transcriptJson         String?
  /// 自研录音：本地文件相对路径（uploads/recordings/...）
  recordingPath          String?
  recordingMimeType      String?
  recordingBytes         Int?
  recordingStartedAt     DateTime?
  recordingEndedAt       DateTime?
  /// idle | recording | uploaded | transcribing | ready | error
  transcriptStatus       String?
  transcriptError        String?
  liveNotes              String? // 会中侧栏记录本（含 <<<PARTNER:id|name>>> 标记）
  prepGeneratedAt        DateTime?
  /// 会前预览分享 token（无需登录即可查看议程与简报）
  previewToken           String?  @unique
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  items                  PartnerReviewItem[]

  @@index([status])
  @@index([createdById])
  @@index([dingtalkRecordId])
}

// 会议中的单个伙伴议程项
model PartnerReviewItem {
  id                String   @id @default(cuid())
  meetingId         String
  meeting           PartnerReviewMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  partnerId         String
  partner           Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  sortOrder         Int      @default(0)
  discussedAt       DateTime?
  markerInsertedAt  DateTime?
  prepBrief         String? // JSON：进展 / 待办 / AI 议题
  coreNotes         String? // 会后确认的核心讨论摘要
  // JSON：确认入库时的完整摘要快照（商务记录标题/正文、待办、是否跳过等）
  confirmedSnapshot String?
  // PENDING | DISCUSSED | CONFIRMED
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  todoDrafts        PartnerReviewTodoDraft[]

  @@unique([meetingId, partnerId])
  @@index([meetingId, sortOrder])
  @@index([partnerId])
}

// 会后待办草案（确认后写入 TodoItem）
model PartnerReviewTodoDraft {
  id         String   @id @default(cuid())
  itemId     String
  item       PartnerReviewItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  title      String
  detail     String?
  assigneeId String?
  dueDate    DateTime?
  confirmed  Boolean  @default(false)
  todoItemId String? // 确认落库后的 TodoItem.id
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([itemId])
}
